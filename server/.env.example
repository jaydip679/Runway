# Environment Configuration
NODE_ENV=development
PORT=4000

# Client Configuration
CLIENT_URL=http://localhost

# Database (PostgreSQL)
# For local migration execution outside docker, you may need to use localhost instead of postgres
DATABASE_URL=postgresql://runway:runway@postgres:5432/runway

# Redis
REDIS_URL=redis://redis:6379

# Security & Authentication (MUST be at least 32 characters)
JWT_ACCESS_SECRET=your_super_secret_jwt_key_here_must_be_long
REFRESH_TOKEN_HASH_SECRET=your_super_secret_refresh_key_here_must_be_long

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost/api/v1/auth/google/callback

# Cloudinary (Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Provider Configuration
AI_PROVIDER=openai # Or gemini
OPENAI_API_KEY=your_openai_api_key
# GEMINI_API_KEY=your_gemini_api_key
AI_DAILY_QUERY_LIMIT=20

# SMTP / Email
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM=noreply@runway.local

# Seeding
ADMIN_SEED_EMAIL=admin@runway.local
ADMIN_SEED_PASSWORD=supersecureadminpass

# Application Config
LOG_LEVEL=debug
FORECAST_WINDOW_DAYS=60
LOW_BALANCE_THRESHOLD=0
