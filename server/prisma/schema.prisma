generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?
  name             String
  avatarUrl        String?
  role             Role      @default(USER)
  authProvider     AuthProvider
  googleId         String?   @unique
  isEmailVerified  Boolean   @default(false)
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  accounts             Account[]
  categories           Category[]
  transactions         Transaction[]
  csvImportJobs        CsvImportJob[]
  recurringCommitments RecurringCommitment[]
  forecastSnapshots    ForecastSnapshot[]
  alerts               Alert[]
  aiQueryLogs          AiQueryLog[]
  budgets              Budget[]
  savingsGoals         SavingsGoal[]
  recurringOccurrences RecurringOccurrence[]
  exportDocuments      ExportDocument[]

  @@index([email])
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

model RefreshToken {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  tokenHash     String
  familyId      String
  expiresAt     DateTime
  revokedAt     DateTime?
  createdByIp   String?
  createdAt     DateTime  @default(now())

  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([tokenHash])
}

model AuditLog {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  action      String
  entityType  String
  entityId    String
  metadata    Json
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

model Account {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  name            String
  type            AccountType
  currentBalance  Decimal     @db.Decimal(14, 2)
  currency        String      @default("INR")
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?

  transactions          Transaction[]
  csvImportJobs         CsvImportJob[]
  recurringCommitments  RecurringCommitment[]
  savingsGoalAccounts   SavingsGoalAccount[]

  @@index([userId, deletedAt])
}

enum AccountType { 
  BANK 
  CASH 
  WALLET 
  CREDIT_CARD 
}

model Category {
  id        String        @id @default(uuid())
  userId    String?       // null = system-defined global category
  user      User?         @relation(fields: [userId], references: [id])
  name      String
  type      CategoryType
  icon      String?
  isSystem  Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name, type])
}

enum CategoryType { 
  INCOME 
  EXPENSE 
}

model Transaction {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  accountId         String
  account           Account             @relation(fields: [accountId], references: [id])
  categoryId        String?
  category          Category?           @relation(fields: [categoryId], references: [id])
  amount            Decimal             @db.Decimal(14, 2)
  type              TransactionType
  description       String
  transactionDate   DateTime            @db.Date
  source            TransactionSource   @default(MANUAL)
  receiptImageUrl   String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  recurringOccurrence RecurringOccurrence?

  @@index([userId, transactionDate])
  @@index([accountId, transactionDate])
  @@index([userId, categoryId])
  @@index([userId, deletedAt])
}

enum TransactionType { 
  INCOME 
  EXPENSE 
}

enum TransactionSource { 
  MANUAL 
  CSV_IMPORT 
}

model CsvImportJob {
  id           String            @id @default(uuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id])
  accountId    String
  account      Account           @relation(fields: [accountId], references: [id])
  status       CsvImportStatus   @default(PENDING)
  totalRows    Int
  successRows  Int               @default(0)
  failedRows   Int               @default(0)
  errorLog     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId, status])
  @@index([status])
}

enum CsvImportStatus { 
  PENDING 
  PROCESSING 
  COMPLETED 
  FAILED 
}

model RecurringCommitment {
  id                  String            @id @default(uuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id])
  accountId           String
  account             Account           @relation(fields: [accountId], references: [id])
  name                String
  amount              Decimal           @db.Decimal(14, 2)
  type                TransactionType
  intervalUnit        IntervalUnit
  intervalCount       Int               @default(1)
  nextOccurrenceDate  DateTime          @db.Date
  detectionSource     DetectionSource
  confidenceScore     Float?            
  groupSignature      String?           
  status              RecurringStatus   @default(PENDING_CONFIRMATION)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  occurrences         RecurringOccurrence[]

  @@index([userId, status])
  @@index([userId, nextOccurrenceDate])
  @@index([groupSignature])
}

enum IntervalUnit {
  DAILY 
  WEEKLY 
  MONTHLY 
  YEARLY 
}

enum DetectionSource {
  AUTO_DETECTED 
  MANUAL 
}

enum RecurringStatus {
  PENDING_CONFIRMATION 
  CONFIRMED 
  DISMISSED 
  ARCHIVED 
}

model RecurringOccurrence {
  id              String           @id @default(uuid())
  commitmentId    String
  commitment      RecurringCommitment @relation(fields: [commitmentId], references: [id])
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  expectedDate    DateTime         @db.Date
  amount          Decimal          @db.Decimal(14, 2)
  status          OccurrenceStatus @default(PENDING)
  transactionId   String?          @unique
  transaction     Transaction?     @relation(fields: [transactionId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([commitmentId, expectedDate])
  @@index([userId, status])
}

enum OccurrenceStatus {
  PENDING
  COMPLETED
  SKIPPED
  MISSED
}

model ForecastSnapshot {
  id                String            @id @default(uuid())
  userId            String
  user              User              @relation(fields: [userId], references: [id])
  forecastDate      DateTime          @db.Date
  projectedBalance  Decimal           @db.Decimal(14, 2)
  confidenceLevel   ConfidenceLevel
  generatedAt       DateTime          

  @@unique([userId, forecastDate])    
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

model Alert {
  id                 String        @id @default(uuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  type               AlertType
  relatedEntityType  String?       // 'FORECAST' | 'RECURRING_COMMITMENT'
  relatedEntityId    String?
  relevantDate       DateTime?     @db.Date
  message            String
  severity           AlertSeverity
  isRead             Boolean       @default(false)
  createdAt          DateTime      @default(now())

  @@index([userId, isRead, createdAt])
  @@unique([userId, type, relatedEntityId, relevantDate])
}

enum AlertType {
  LOW_BALANCE_PREDICTED
  RECURRING_RENEWAL_UPCOMING
  RECURRING_DETECTED_PENDING_CONFIRMATION
  EXPORT_READY
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model AiQueryLog {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  question   String    @db.Text
  answer     String?   @db.Text
  succeeded  Boolean
  createdAt  DateTime  @default(now())

  @@index([userId, createdAt])
}

model Budget {
  id         String     @id @default(uuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  categoryId String
  category   Category   @relation(fields: [categoryId], references: [id])
  amount     Decimal    @db.Decimal(14, 2)
  period     Period     @default(MONTHLY)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([userId, categoryId, period])
}

enum Period {
  MONTHLY
  YEARLY
}

model SavingsGoal {
  id            String               @id @default(uuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id])
  name          String
  targetAmount  Decimal              @db.Decimal(14, 2)
  targetDate    DateTime             @db.Date
  currentAmount Decimal              @default(0) @db.Decimal(14, 2)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  linkedAccounts SavingsGoalAccount[]

  @@index([userId, targetDate])
}

model SavingsGoalAccount {
  goalId    String
  goal      SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  accountId String
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@id([goalId, accountId])
}

model ExportDocument {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  cloudPublicId   String
  secureUrl       String
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
}
